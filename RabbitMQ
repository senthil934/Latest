7. Create Consumer (ACK + Retry + Idempotency)

import org.springframework.amqp.core.Message;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.amqp.rabbit.core.RabbitTemplate;
import org.springframework.stereotype.Component;

import com.pack.Springboot_Rabbitmq_Reliability.domain.OrderEvent;
import com.pack.Springboot_Rabbitmq_Reliability.domain.ProcessedEvent;
import com.pack.Springboot_Rabbitmq_Reliability.domain.ProcessedEventRepository;
import com.rabbitmq.client.Channel;

@Component
public class OrderConsumer {

    private final RabbitTemplate rabbitTemplate;
    private final ProcessedEventRepository repo;

    public OrderConsumer(RabbitTemplate rabbitTemplate,
                         ProcessedEventRepository repo) {
        this.rabbitTemplate = rabbitTemplate;
        this.repo = repo;
    }

    @RabbitListener(queues = "order.main")
    public void consume(OrderEvent event,
                        Message message,
                        Channel channel) throws Exception {

        long tag = message.getMessageProperties().getDeliveryTag();
        int retryCount = (int) message.getMessageProperties()
                .getHeaders()
                .getOrDefault("x-retry-count", 0);

        System.out.println("[MAIN] orderId=" + event.orderId()
                + " retryCount=" + retryCount);

        // Idempotency
        if (repo.existsById(event.eventId())) {
            channel.basicAck(tag, false);
            return;
        }

        try {
            if (retryCount < 3) {
                throw new RuntimeException("Simulated failure");
            }

            repo.save(new ProcessedEvent(event.eventId()));
            channel.basicAck(tag, false);

        } catch (Exception e) {

            if (retryCount < 3) {
                rabbitTemplate.convertAndSend(
                        "order.dlx",
                        "retry",
                        event,
                        msg -> {
                            msg.getMessageProperties()
                               .getHeaders()
                               .put("x-retry-count", retryCount + 1);
                            return msg;
                        }
                );
            } else {
                rabbitTemplate.convertAndSend("order.dlx", "dlq", event);
            }

            channel.basicAck(tag, false);
        }
    }
}

