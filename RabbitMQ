Consumer  retry  with  backoff  delays  using RabbitMQ  TTL  +  Dead‑Lettering (DLX).
      RabbitMQ  can  dead‑letter  a  message  when  it  is  rejected/nacked  with  requeue=false  or  when  it  expires  due  to  TTL.   You  can  build  delayed  retries  by  publishing  the  failed  message  to  a  retry  queue  that  has:

1. x-message-ttl = delayMs
2. x-dead-letter-exchange = mainExchange
3. x-dead-letter-routing-key = mainRoutingKey

After  TTL,  the  message  expires  and  is  dead‑lettered  back  to  the  main  queue  for  reprocessing. 

1. Create  Springboot-RabbitMQ-RetryTTL with web, spring for RabbitMQ dependency

2. Configure RabbitMQ properties in application.properties

3.  Define  topology:  main queue + retry  queues (TTL)

Queues:
- demo.work.q  (consumer listens here)
- demo.retry.5s.q  (TTL 5s, DLX back to main)
- demo.retry.30s.q  (TTL 30s, DLX back to main)
- demo.retry.2m.q  (TTL 120s, DLX back to main)
- demo.parking.q  (final failed messages)

Why  this  works: Messages  can  be  dead‑lettered  when  their  TTL  expires  and  a  delayed  system  can  be  built  by  combining  x-message-ttl  with  x-dead-letter-exchange. 

@Configuration
public class RabbitRetryTopology {

    // Exchanges
    public static final String MAIN_EXCHANGE = "demo.main.x";
    public static final String RETRY_EXCHANGE = "demo.retry.x";
    public static final String PARKING_EXCHANGE = "demo.parking.x";

    // Routing keys
    public static final String WORK_RK = "work";
    public static final String RETRY_5S_RK = "retry.5s";
    public static final String RETRY_30S_RK = "retry.30s";
    public static final String RETRY_2M_RK = "retry.2m";
    public static final String PARKING_RK = "parking";

    // Queues
    public static final String WORK_Q = "demo.work.q";
    public static final String RETRY_5S_Q = "demo.retry.5s.q";
    public static final String RETRY_30S_Q = "demo.retry.30s.q";
    public static final String RETRY_2M_Q = "demo.retry.2m.q";
    public static final String PARKING_Q = "demo.parking.q";

    @Bean
    public DirectExchange mainExchange() {
        return new DirectExchange(MAIN_EXCHANGE, true, false);
    }

    @Bean
    public DirectExchange retryExchange() {
        return new DirectExchange(RETRY_EXCHANGE, true, false);
    }

    @Bean
    public DirectExchange parkingExchange() {
        return new DirectExchange(PARKING_EXCHANGE, true, false);
    }

    @Bean
    public Queue workQueue() {
        return QueueBuilder.durable(WORK_Q).build();
    }

    // Retry queues: TTL + DLX back to main exchange
    @Bean
    public Queue retry5sQueue() {
        return QueueBuilder.durable(RETRY_5S_Q)
                .withArguments(Map.of(
                        "x-message-ttl", 5000,
                        "x-dead-letter-exchange", MAIN_EXCHANGE,
                        "x-dead-letter-routing-key", WORK_RK
                ))
                .build();
    }

    @Bean
    public Queue retry30sQueue() {
        return QueueBuilder.durable(RETRY_30S_Q)
                .withArguments(Map.of(
                        "x-message-ttl", 30000,
                        "x-dead-letter-exchange", MAIN_EXCHANGE,
                        "x-dead-letter-routing-key", WORK_RK
                ))
                .build();
    }

    @Bean
    public Queue retry2mQueue() {
        return QueueBuilder.durable(RETRY_2M_Q)
                .withArguments(Map.of(
                        "x-message-ttl", 120000,
                        "x-dead-letter-exchange", MAIN_EXCHANGE,
                        "x-dead-letter-routing-key", WORK_RK
                ))
                .build();
    }

    @Bean
    public Queue parkingQueue() {
        return QueueBuilder.durable(PARKING_Q).build();
    }

    // Bindings
    @Bean
    public Binding workBinding(Queue workQueue, DirectExchange mainExchange) {
        return BindingBuilder.bind(workQueue).to(mainExchange).with(WORK_RK);
    }

    @Bean
    public Binding retry5sBinding(Queue retry5sQueue, DirectExchange retryExchange) {
        return BindingBuilder.bind(retry5sQueue).to(retryExchange).with(RETRY_5S_RK);
    }

    @Bean
    public Binding retry30sBinding(Queue retry30sQueue, DirectExchange retryExchange) {
        return BindingBuilder.bind(retry30sQueue).to(retryExchange).with(RETRY_30S_RK);
    }

    @Bean
    public Binding retry2mBinding(Queue retry2mQueue, DirectExchange retryExchange) {
        return BindingBuilder.bind(retry2mQueue).to(retryExchange).with(RETRY_2M_RK);
    }

    @Bean
    public Binding parkingBinding(Queue parkingQueue, DirectExchange parkingExchange) {
        return BindingBuilder.bind(parkingQueue).to(parkingExchange).with(PARKING_RK);
    }
}


