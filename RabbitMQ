7. Create  Consumer  with  Retry + Backoff + TTL routing
      When  processing  fails,  we  republish  the  message  to  the  correct  retry  queue  route (5s → 30s → 2m). Those  queues  hold  the  message until  TTL  expires,  then  they  DLX  it  back  to  the  main  queue.

@Component
public class WorkConsumer {

	@Autowired
	RabbitTemplate rabbitTemplate;

	// Backoff schedule (ms): 5s, 30s, 2m
	private final List<Integer> delays = List.of(5000, 30000, 120000);

	@RabbitListener(queues = RabbitRetryTopology.WORK_Q, containerFactory = "rabbitListenerContainerFactory")
	public void onMessage(Message message, Channel channel, @Header(AmqpHeaders.DELIVERY_TAG) long tag)
			throws IOException {

		String body = new String(message.getBody(), StandardCharsets.UTF_8);
		Integer retryCount = (Integer) message.getMessageProperties().getHeaders().getOrDefault("x-retry-count", 0);

		try {
			// ---- Simulated business logic ----
			System.out.println("[WORK] Received: " + body + " retryCount=" + retryCount);

			// Example: fail first 2 attempts if payload contains "fail"
			if (body.contains("fail") && retryCount < 2) {
				throw new RuntimeException("Simulated processing failure");
			}

			// SUCCESS
			channel.basicAck(tag, false);
			System.out.println("[WORK] ACK success: " + body);

		} catch (Exception ex) {
			System.out.println("[WORK] ERROR: " + ex.getMessage() + " body=" + body);

			// Decide: retry or park
			if (retryCount < delays.size()) {
				// Route to a retry queue with increasing delay
				String rk = routingKeyFor(retryCount);

				int nextRetry = retryCount + 1;

				rabbitTemplate.convertAndSend(RabbitRetryTopology.RETRY_EXCHANGE, rk, body, msg -> {
					msg.getMessageProperties().getHeaders().putAll(message.getMessageProperties().getHeaders());
					msg.getMessageProperties().setHeader("x-retry-count", nextRetry);
					msg.getMessageProperties().setHeader("x-last-error", ex.getClass().getSimpleName());
					return msg;
				});

				// ACK original so it doesn't loop immediately
				channel.basicAck(tag, false);
				System.out.println("[WORK] Sent to retry (" + rk + ") nextRetry=" + nextRetry);

			} else {
				// Exhausted retries -> parking lot
				rabbitTemplate.convertAndSend(RabbitRetryTopology.PARKING_EXCHANGE, RabbitRetryTopology.PARKING_RK,
						body, msg -> {
							msg.getMessageProperties().getHeaders().putAll(message.getMessageProperties().getHeaders());
							msg.getMessageProperties().setHeader("x-final-failure", true);
							msg.getMessageProperties().setHeader("x-last-error", ex.getClass().getSimpleName());
							return msg;
						});

				channel.basicAck(tag, false);
				System.out.println("[WORK] Parked message after retries exhausted: " + body);
			}
		}
	}

	private String routingKeyFor(int retryCount) {
		// retryCount=0 => first failure => 5s queue
		// retryCount=1 => second failure => 30s queue
		// retryCount=2 => third failure => 2m queue
		return switch (retryCount) {
		case 0 -> RabbitRetryTopology.RETRY_5S_RK;
		case 1 -> RabbitRetryTopology.RETRY_30S_RK;
		default -> RabbitRetryTopology.RETRY_2M_RK;
		};
	}
}

