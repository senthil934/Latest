    public static final String Q_CREATED_DLQ = "q.order.created.dlq";
    public static final String Q_CANCELLED_DLQ = "q.order.cancelled.dlq";
    public static final String RK_CREATED_DLQ = "dlq.order.created";
    public static final String RK_CANCELLED_DLQ = "dlq.order.cancelled";

    // TTL for main queues (ms)
    public static final int TTL_MS = 15000;

    @Bean
