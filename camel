By injecting in this way we can then use this template to send our messages without specifying destination each time by just specifying body and then header.

- We have our ExampleMessageTransformer is mocked and it is called in our route to transform our message and verifying that it's transform method which processes our exchange is called exactly once 

- @CamelSpringBootTest ensures that Camelcontext starts and stops as it is needed for testing
classes, so in general just add this annotation to your spring boot camel tests

@CamelSpringBootTest
@SpringBootTest
public class ExampleRouteTest {

    @Autowired
    private CamelContext camelContext;

    @MockBean
    private ExampleMessageTransformer transformerMock;

    private final String directTestEndpoint = "direct:example-route-test";

    @EndpointInject("mock:example-route-test")
    private MockEndpoint mock;

    @Produce(directTestEndpoint)
    private ProducerTemplate template;

    @BeforeEach
    public void replaceEndpoints() throws Exception {
        AdviceWith.adviceWith(
                camelContext,
                ExampleRoute.ID,
                route -> route
                        .interceptSendToEndpoint("jms:{{example.queue.output.name}}")
                        .skipSendToOriginalEndpoint()
                        .to(mock)
        );
        AdviceWith.adviceWith(
                camelContext,
                ExampleRoute.ID,
                route -> route.replaceFromWith(directTestEndpoint)
        );
    }

    @Test
    void testExampleRoute() throws Exception {
        String testBody = "test-body";
        String testHeader = "test-header";
        mock.expectedMessageCount(1);

        template.sendBodyAndHeader(testBody, "example-header", testHeader);

        verify(transformerMock, times(1)).transform(any());
        mock.assertIsSatisfied();
    }
}



