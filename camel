3. Create ExampleMessageTransformer bean with 2 beans ExampleMessageBodyMapper, ExampleMessageHeaderMapper and transform() method accepts exchange


@Service("exampleMessageTransformer")
public class ExampleMessageTransformer {

    private final ExampleMessageBodyMapper bodyMapper;

    private final ExampleMessageHeaderMapper headerMapper;

    public ExampleMessageTransformer(ExampleMessageBodyMapper bodyMapper, ExampleMessageHeaderMapper headerMapper) {
        this.bodyMapper = bodyMapper;
        this.headerMapper = headerMapper;
    }

    public void transform(Exchange exchange) {
        Message msg = exchange.getMessage();
        String headerKey = "example-header";

        // Body mapping (null-safe)
        String body = msg.getBody(String.class);
        msg.setBody(bodyMapper.map(body));

        // Header mapping (null-safe)
        String headerVal = msg.getHeader(headerKey, String.class);
        msg.setHeader(headerKey, headerMapper.map(headerVal));
    }
}


@Service
public class ExampleMessageBodyMapper {

	 public String map(String input) {
	        return (input != null) ? input.toUpperCase() : "DEFAULT_BODY";
	 }
}


@Service
public class ExampleMessageHeaderMapper {

	public String map(String input) {
        return (input != null) ? input.toUpperCase() : "DEFAULT_HEADER";
    }
}


