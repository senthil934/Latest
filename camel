        .doTry()
        .process(exchange -> {
            throw new RuntimeException("Test exception");
        })
        .doCatch(Exception.class).onWhen(simple("${exception.message} contains 'Example'"))
        .log("Catch Exception: ${exception}")
        .doFinally()
        .log("Finally: ${exception}")
        .end()
