// fetch single course
func getOneCourse(w http.ResponseWriter, r *http.Request) {
	fmt.Println("Get one course")
	w.Header().Set("Content-Type", "application/json")

	//fetch id from request using mux.Vars() which extract all vatiables from request and returns    	//key value pairs
	params := mux.Vars(r)

	// loop through courses, and return the response
	//We are not worried about the index so we give _, and take only the value and we are looping 	//through a range of courses
	for _, course := range courses {
		// find matching id - course is having a lot of properties and we take courseid, if that 			//matches to something the id which is user is passing me which is stored inside the 				//params, since params is a key value pair we have to mention that user is sending me with 		//the name of id
		if course.CourseId == params["id"] {
			//To return the response we  use this json library provides with NewEncoder which takes 			//writer, and call Encode() and we want to send entire course to writer
			json.NewEncoder(w).Encode(course)
			return
		}
	}

	//if id is not found
	json.NewEncoder(w).Encode("No Course found with given id")
	return
}


