// get all movies from database
func getAllMovies() []primitive.M {

	/*we need a collection which has a property Find() which takes on the context we use the context.background and then we have to provide a filter as  bson.M or bson.D with empty parenthesis that means everything*/
	//It returns an a cursor or error so we use comma ok syntax
	cur, err := collection.Find(context.Background(), bson.D{{}})
	
	//check for error
	if err != nil {
		log.Fatal(err)
	}

	/*we have this cursor now we have to declare a variable movies which is an array of type M, remember we have the bson.d or bson.M but since we are using this primitive package we have primitive.A, preventive.M or D. In the queries you can use bson.d whatever you like, since we are creating a variable of that type we have to use M */
	var movies []primitive.M

	// We have cursor now we loop through inside it, we use a for loop but in the style of while loop 
   //cursor has a property next() where we have to pass on a context and it will keep on giving you the result as much as it has the next value
	for cur.Next(context.Background()) {

		//create a variable of type bson.M 
		var movie bson.M

		//we use Decode() which takes a pointer of movie variable, it will decode the value from the cursor and put it into the movie variable
		//this either is going to decode and this movie will be fulfilled with the values or it falls into anerror 
		err := cur.Decode(&movie)

		//check for error
		if err != nil {
			log.Fatal(err)
		}

		//use this variable and push this into an array using append
		movies = append(movies, movie)
	}

	//close the cursor passing the context
	defer cur.Close(context.Background())
	return movies
}


