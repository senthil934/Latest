	"net/http"
	"strings"
)

func main() {
	fmt.Println("Handling Web Requests in Golang")
	PerformGetRequest() //call the function
}

// Create get request
func PerformGetRequest() {
	const myurl = "http://localhost:8000/get"

	//making get request using http pkg, returns either response or error so we use comma ok syntax
	response, err := http.Get(myurl)

	//check for error
	if err != nil {
		panic(err)
	}

	//close the request with defer
	defer response.Body.Close()

	fmt.Println("Status code: ", response.StatusCode)
	fmt.Println("Content length is: ", response.ContentLength)

	//read the content of response body, it might give content or error so we use comma ok syntax
	//content, _ := io.ReadAll(response.Body)
	//fmt.Println(content)  //byte format
	//fmt.Println(string(content))

	//Another way to handle the response, using strings package builder() method, used to build a string using write() method
	var responseString strings.Builder
	content, _ := io.ReadAll(response.Body)

	byteCount, _ := responseString.Write(content)

	fmt.Println("ByteCount is: ", byteCount)

	//your response is still inside this responsestring, just like it has a method of write(), it has a method to
	//just throw away this data as well called String()
	fmt.Println(responseString.String())
}

