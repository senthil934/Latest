package main

import (
	"fmt"
	"net/url"
)

// create a url
const myUrl string = "https://abc.com:3000/learn?coursename=go&paymentId=sbcd123"

func main() {
	fmt.Println("Handling Urls in Golang")
	fmt.Println(myUrl)

	//1. We have url now we get info from url
	//parsing the url which means we  want to extract some information from url, using url package
	//once we parse we receive the result which has more info, may be ur url is correct or malformed url so we use comma ok syntax
	result, _ := url.Parse(myUrl)

	fmt.Println(result.Scheme)
	fmt.Println(result.Host)
	fmt.Println(result.Port())
	fmt.Println(result.Path)
	fmt.Println(result.RawQuery)

	//Query() actually just stores all these query parameters into a better format
	qParams := result.Query()
	fmt.Printf("The type of query params %T\n", qParams) //url.values are key values types

	fmt.Println(qParams["coursename"])

	for _, val := range qParams {
		fmt.Println("Param values are ", val)
	}

	//2. We have all info abt url, we need to construct a url
	//in this case you don't want to pass on a copy of url instead we pass on a reference of url
	partsOfUrl := &url.URL{
		Scheme:  "https",
		Host:    "abc.com",
		Path:    "/tutorials",
		RawPath: "user=Ram",
	}

	//construct a string out of a url
	anotherUrl := partsOfUrl.String()
	fmt.Println(anotherUrl)
}


