Update a course controller in golang
      In case of update, we find one course based on unique course id and need to fetch all those values that should be updated this is a regular operation. Since we are not in the database, first 
we're going to loop through all the values and once we hit the value which is given by us as an id, then we're going slice off that value from slice which is having different values, then we're going to just remove that value and since we have that id already in our params we're going to just inject that value

//Update the course
func updateOneCourse(w http.ResponseWriter, r *http.Request) {
	fmt.Println("Update one course")
	w.Header().Set("Content-Type", "applicatioan/json")

	// fetch id from req using mux.Vars()
	params := mux.Vars(r)

	// loop through value
	for index, course := range courses {
		//check for each id with whatever value that we provided which is present in params, if it 		//is present we remove that course from slice of courses
		if course.CourseId == params["id"] {

			//remove course from slice
			courses = append(courses[:index], courses[index+1:]...)

            //Now we want to add a new value based on the id, so we need to grab two things, the 				//id which we already have in the params but we don't have the values to add,
			// so we need to grab that from the request body

			var course Course

			//Use json.NewDecoder() and fetch values from the body (ie) r.body and and you will be 				//decoding that through a reference called course, so now we decode the json based on  				//this course 
			_ = json.NewDecoder(r.Body).Decode(&course)

			//we need to have a unique id, we are already generating a unique id but in this case
		//since this is an update operation the id should remain same, so we take id from params 
			course.CourseId = params["id"]

			//add updated course in slice
			courses = append(courses, course)

			//send encoded response 
			json.NewEncoder(w).Encode(course)
			return
		}
	}
	
}


