package main

import (
	"fmt"
	"io"
	"net/http"
)

// create a variable where the url is defined
const url = "https://spring.io/blog/category/news"

func main() {
	fmt.Println("WebRequest in Golang")

	//create simple HTTP request from net pkg with get() it requires just one parameter which is url
	//once you are making a request, your request may or may not success, so we use comma ok syntax to check if the request was successful
	response, err := http.Get(url)

	//check error
	if err != nil {
		panic(err)
	}

	//check type of response
	fmt.Printf("Response is of type %t\n", response) //*http.response
	//it says *http.response so this is not an ordinary bytes or an ordinary string
	//you get a reference of the original response that we have received so that you can manipulate it further

	defer response.Body.Close() //close the response body at the end of the function since we used defer

	//read this response using io.ReadAll() which reads from all formats
	data, err := io.ReadAll(response.Body)

	//check error
	if err != nil {
		panic(err)
	}

	content := string(data)
	fmt.Println(content)
}


