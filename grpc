@Service
public class AuthGrpcService extends AuthServiceImplBase {

    private final JwtService jwtService;

    // Demo users (replace with DB/LDAP in real apps)
    private final Map<String, UserRecord> users = Map.of(
            "user1", new UserRecord("pass1", List.of("USER")),
            "admin1", new UserRecord("adminpass", List.of("ADMIN", "USER"))
    );

    public AuthGrpcService(JwtService jwtService) {
        this.jwtService = jwtService;
    }

    @Override
    public void login(AuthRequest request, StreamObserver<AuthResponse> responseObserver) {
        String username = request.getUsername();
        String password = request.getPassword();

        UserRecord user = users.get(username);
        if (user == null || !user.password().equals(password)) {
            responseObserver.onError(
                    Status.UNAUTHENTICATED.withDescription("Bad credentials").asRuntimeException()
            );
            return;
        }

        long expiresInSec = 3600; // 1 hour
        String token = jwtService.generateToken(username, user.roles(), expiresInSec);

        AuthResponse response = AuthResponse.newBuilder()
                .setToken(token)
                .setTokenType("Bearer")
                .setExpiresInSec(expiresInSec)
                .addAllRoles(user.roles())
                .build();

        responseObserver.onNext(response);
        responseObserver.onCompleted();
    }

    private record UserRecord(String password, List<String> roles) {}
}

