@Autowired
StockRepository stockRepository;

    @Override
    public void getStockPrice(StockRequest request,
                              StreamObserver<StockResponse> responseObserver) {

        //stockName -> DB -> map response -> return

        // first get the symbol name which you will get from the request getSymbol 
        String stockSymbol = request.getStockSymbol();

        //call the repository to fetch stock from db
        Stock stockEntity = stockRepository.findByStockSymbol(stockSymbol);

        //we can use the Builder class given by grpc and map the stockentity information to stockresponse
        StockResponse stockResponse = StockResponse.newBuilder()
                .setStockSymbol(stockEntity.getStockSymbol())
                .setPrice(stockEntity.getPrice())
                .setTimestamp(stockEntity.getLastUpdated().toString())
                .build();

        //send this stockresponse object to this responseObserver 
        responseObserver.onNext(stockResponse);
        responseObserver.onCompleted();

    }

