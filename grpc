public final class CustomMetadataUtil {

    private static final Metadata.Key<CustomError> ERROR_KEY =
            ProtoUtils.keyForProto(CustomError.getDefaultInstance());

    private CustomMetadataUtil() {}

    public static Metadata customerNotFound(String message) {
        Metadata metadata = new Metadata();
        metadata.put(
                ERROR_KEY,
                CustomError.newBuilder()
                        .setMessage(message)
                        .setErrorType("NOT_FOUND")
                        .build()
        );
        return metadata;
    }
}

2. Create central error mapper class

public final class GrpcErrorMapper {

    private GrpcErrorMapper() {}

    public static StatusRuntimeException map(Throwable error) {

        if (error instanceof CustomerNotFoundException ex) {
            Metadata metadata =
                    CustomMetadataUtil.customerNotFound(ex.getMessage());

            return Status.NOT_FOUND
                    .withDescription(ex.getMessage())
                    .asRuntimeException(metadata);
        }

        if (error instanceof IllegalArgumentException ex) {
            return Status.INVALID_ARGUMENT
                    .withDescription(ex.getMessage())
                    .asRuntimeException();
        }

        // fallback
        return Status.INTERNAL
                .withDescription("Internal server error")
                .withCause(error)
                .asRuntimeException();
    }
}

