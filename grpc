- Now create switch case in onNext,  if the customer error is the case then we get the custom error if the customer is the case then we'll get the get customer

@Override
	public void run(ApplicationArguments args) throws Exception {
		final CountDownLatch countDownLatch=new CountDownLatch(1);
		asyncStub.getCustomers(Empty.newBuilder().build(), new StreamObserver<CustomerDetails>() {

			//We know that on the server side all the data and errors is treated as the data so all the information would come on the onnext and nothing will come on onerror
			@Override
			public void onNext(CustomerDetails value) {
				switch(value.getMessageCase()) {
				case CUSTOMERROR:
					System.out.println(value.getCustomError());
				case CUSTOMER:
				    System.out.println(value.getCustomer());
				}
			}

			@Override
			public void onError(Throwable t) {
				// TODO Auto-generated method stub
				
			}

			@Override
			public void onCompleted() {
				countDownLatch.countDown();
			}
		});
		//ask the main thread to wait until it's until that counts are zero
		countDownLatch.await();
	}


