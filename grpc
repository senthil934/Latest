  @Override
    public void subscribeStockPrice(StockRequest request, StreamObserver<StockResponse> responseObserver) {
        //get the symbol from the request
        String symbol=request.getStockSymbol();

//Now We loop 10 times and for every 1 second will emit one stock response event specific to that stock symbol and simulate to validate the behavior of server streaming
        try {
            for (int i = 0; i <= 10; i++) {
                //Each loop will send one stockresponse object, we are not fetching it from
the DB, so we dynamically build it
                StockResponse stockResponse = StockResponse.newBuilder()
                        .setStockSymbol(symbol)
                        .setPrice(10 + (200 - 10) * new Random().nextDouble())
                        .setTimestamp(Instant.now().toString())
                        .build();

				//now we emit one response to the client 
                responseObserver.onNext(stockResponse);
               //my thread will sleep for 1 second. and the loop continue till 10 times 
                TimeUnit.SECONDS.sleep(1);
            }
             //we tell to the responseobserver the task is completed
            responseObserver.onCompleted();
        }
        //if any error we can catch it
        catch (Exception ex){
            responseObserver.onError(ex);
        }
    }

