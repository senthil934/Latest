				.defaultOptions(AzureOpenAiChatOptions.builder().temperature(0.3).maxTokens(200).build())
				.build();
		this.vectorStore=vectorStore;
	}

	@GetMapping("/chat")
	public ResponseEntity<String> chat(@RequestParam(value = "q", required = true) String query) {
		
		//load data from vector database
		SearchRequest searchRequest = SearchRequest.builder()
				                      .topK(3)  //how many top results to return (e.g., 3 or 5). Avoid large numbers because more context means higher token usage and cost.
				                      .similarityThreshold(0.6) //used to filter the response.  A value between 0.0 and 1.0, 1.0 means exact match only, 0.0 means very loose matching, A good range is 0.5–0.7 for balanced results.
		                              .query(query)  //user’s query.
		                              .build();
		
		 List<Document> documents = vectorStore.similaritySearch(searchRequest);
		 List<String> documentList = documents.stream().map(Document::getText).toList();  //extract the text from these documents:
		 String contextData = String.join(", ", documentList);  // contextData will contain all relevant sentences joined by commas.
		 log.info("Context Data: {}", contextData);
		 
		String str = chatClient.prompt()
				.system(system -> system.text(this.systemMessage).param("documents", contextData))
				.user(user -> user.text(this.userMessage).param("query", query)).call().content();
		
		return ResponseEntity.ok(str);
	}

}


