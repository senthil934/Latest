    @Override
    public void run(String... args) {
        //read the pdf using TikaDocumentReader which passes actual document
        TikaDocumentReader reader = new TikaDocumentReader(resource);

        //split the pdf contents into chunks using TextSplitter 
        TextSplitter textSplitter = new TokenTextSplitter();

        //split this document into multiple chunks using split()
        List<Document> documents = textSplitter.split(reader.read());
        log.info("Ingesting PDF file");

