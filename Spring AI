@RestController
@RequestMapping("/audio")
public class AudioController {

	private final OpenAIClient openAIClient;

	@Value("${spring.ai.azure.openai.audio.transcription.options.deployment-name}")
	private String deploymentName;

	public AudioController(OpenAIClient openAIClient) {
		this.openAIClient = openAIClient;
	}

	@GetMapping("/transcribe")
	public String transcribeAudio(@RequestParam("filename") String name) throws IOException {

      //Loads file from classpath
		ClassPathResource audioResource = new ClassPathResource(name);

      //Audio is now loaded as raw byte[] which Azure OpenAI expects
		try (InputStream in = audioResource.getInputStream()) {
			byte[] bytes = in.readAllBytes();

//use AudioTranscriptionOptions because Azure OpenAI requires a structured request object to describe how the audio should be transcribed, not just the audio bytes themselves.
			AudioTranscriptionOptions opts = new AudioTranscriptionOptions(bytes).setFilename("sample.m4a") 
					.setResponseFormat(AudioTranscriptionFormat.VERBOSE_JSON);

//Calling Azure OpenAI
			return openAIClient.getAudioTranscription(deploymentName, audioResource.getFilename(), opts).getText();

		} catch (Exception e) {
			throw new RuntimeException(e);
		}

	}
}


