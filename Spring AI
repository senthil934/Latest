@Component
public class ReferenceDocsLoader {

    //create a logger 
    private static final Logger log = LoggerFactory.getLogger(ReferenceDocsLoader.class);

    //get access to the jdbc client
    private final JdbcClient jdbcClient;

    //get a vectorstore instance which gets instance of PGVectorStore or SimpleVectorStore
    private final VectorStore vectorStore;

    //need a resource to access to that PDF 
    @Value("classpath:/docs/spring-boot-reference.pdf")
    private Resource pdfResource;

    //use constructor injection to get jdbcclient and vectorstore
    public ReferenceDocsLoader(JdbcClient jdbcClient, VectorStore vectorStore) {
        this.jdbcClient = jdbcClient;
        this.vectorStore = vectorStore;
    }

    //we have init() method so when this class gets created we are going to run this init method using @PostConstruct
    @PostConstruct
    public void init() {

//using jdbcclient to select count from that Vectorstore which return as an integer
        Integer count = jdbcClient.sql("select count(*) from vector_store")
                .query(Integer.class)
                .single();

        log.info("Current count of the Vector Store: {}", count);

//if that count is zero then we don't have anything in that Vector store so we need to add some document
        if (count == 0) {
            log.info("Loading Spring Boot Reference PDF into Vector Store");

//we use PdfDocumentReaderConfig 
            var config = PdfDocumentReaderConfig.builder()
                    .withPageExtractedTextFormatter(new ExtractedTextFormatter.Builder().withNumberOfBottomTextLinesToDelete(0)
                            .withNumberOfTopPagesToSkipBeforeDelete(0)
                            .build())
                    .withPagesPerDocument(1)
                    .build();

            //we use PagePdfDocumentReader to read from a PDF file  
            var pdfReader = new PagePdfDocumentReader(pdfResource, config);

           //we split it up
            var textSplitter = new TokenTextSplitter();

           //we ask Vectorstore to accept documents that it needs to split up
            vectorStore.accept(textSplitter.apply(pdfReader.get()));

            log.info("Application is ready");
        }
    }
}


@Component
public class ReferenceDocsLoader implements CommandLineRunner {

    private static final Logger log = LoggerFactory.getLogger(ReferenceDocsLoader.class);
    private final JdbcClient jdbcClient;
    private final VectorStore vectorStore;

    @Value("classpath:/docs/spring-boot-reference.pdf")
    private Resource pdfResource;

    public ReferenceDocsLoader(JdbcClient jdbcClient, VectorStore vectorStore) {
        this.jdbcClient = jdbcClient;
        this.vectorStore = vectorStore;
    }

    @Override
    public void run(String... args) throws Exception {
        Integer count = jdbcClient.sql("select count(*) from vector_store")
                .query(Integer.class)
                .single();

        log.info("Current count of the Vector Store: {}", count);
        if (count == 0) {
            log.info("Loading Spring Boot Reference PDF into Vector Store");

            var config = PdfDocumentReaderConfig.builder()
                    .withPageExtractedTextFormatter(new ExtractedTextFormatter.Builder()
                            .withNumberOfBottomTextLinesToDelete(0)
                            .withNumberOfTopPagesToSkipBeforeDelete(0)
                            .build())
                    .withPagesPerDocument(1)
                    .build();

            var pdfReader = new PagePdfDocumentReader(pdfResource, config);
            var textSplitter = new TokenTextSplitter();

            List<Document> docs = textSplitter.apply(pdfReader.get());
            vectorStore.add(docs); // Use add() instead of accept()

            log.info("Application is ready");
        }
    }
}


