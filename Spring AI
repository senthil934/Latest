@Service
public class DocumentIngestionService implements CommandLineRunner {

    private static final Logger log = LoggerFactory.getLogger(DocumentIngestionService.class);

    @Value("classpath:/pdf/spring-boot-reference.pdf")
    private Resource resource;

    private final VectorStore vectorStore;

    public DocumentIngestionService(VectorStore vectorStore) {
        this.vectorStore = vectorStore;
    }

    @Override
    public void run(String... args) {
        //read the pdf using TikaDocumentReader which passes actual document
        TikaDocumentReader reader = new TikaDocumentReader(resource);

        //split the pdf contents into chunks using TextSplitter 
        TextSplitter textSplitter = new TokenTextSplitter();

        //split this document into multiple chunks using split()
        List<Document> documents = textSplitter.split(reader.read());
        log.info("Ingesting PDF file");

        //vectorstore will convert this list of documents into embeddings and then store it inside the vectordatabase.
//vectorstore interface have multiple implementations like PGvectorstore, simplevectorstore,  as we have the autoconfiguration spring boot is automatically going to pick up the PGvector store for us 
        vectorStore.accept(documents);
        log.info("Completed Ingesting PDF file");
    }
}

