6. Create MultiHopSearchService class to write multi-hop retrieval logic 

MultiHopSearchService performs step‑by‑step (multi‑hop) semantic search across related PDF documents stored in a vector database, following document references until the final answer is found.

@Service
public class MultiHopSearchService {

//VectorStore is your semantic search engine. This service does not call the LLM
//It only does: query → embedding → similarity search → metadata inspection
	private final VectorStore vectorStore;

	public MultiHopSearchService(VectorStore vectorStore) {
		this.vectorStore = vectorStore;
	}

//query - The semantic query (e.g. "tax rules"), startDocumentId- Where the search starts (e.g. PDF_1),tenantId - Security boundary, maxHops - How many documents we’re allowed to traverse, topK - Chunks retrieved per hop, threshold - Similarity cutoff
	public Map<String, Object> multiHopSearch(String query, String startDocumentId, String tenantId, int maxHops,int topK, double threshold) {

//Stores results of each hop. Each hop contains:document ID, retrieved text,next references
		List<Map<String, Object>> hops = new ArrayList<>();

		Set<String> visited = new LinkedHashSet<>();

       //sets the entry document: Example:PDF_1 (HR Policy)
		String currentDocId = startDocumentId;

       //Stops when maxHops reached
		for (int hop = 1; hop <= maxHops && currentDocId != null; hop++) {

           //If a document is revisited → stop.
			if (visited.contains(currentDocId))
				break;
			visited.add(currentDocId);

			String filter = "document_id == '" + currentDocId + "' " + "AND tenant_id == '" + tenantId + "'";

			// ✅ Correct query strategy
			String hopQuery = (hop == 1) ? "refer to policy" : query;

			List<Document> retrieved = vectorStore.similaritySearch(SearchRequest.builder().query(hopQuery).topK(topK)
					.similarityThreshold(hop == 1 ? 0.15 : threshold).filterExpression(filter).build());

            // Collect next references from retrieved docs
			Set<String> nextRefs = new LinkedHashSet<>();

//Each chunk has metadata references - ["PDF_2"]. You read that metadata
You collect next documents to visit
			for (Document d : retrieved) {
				Object refs = d.getMetadata().get("references");
				if (refs instanceof List<?> list) {
					for (Object o : list) {
						if (o != null)
							nextRefs.add(o.toString());
					}
				}
			}

           //Record hop result and Stored information per hop
			Map<String, Object> hopResult = new LinkedHashMap<>();
			hopResult.put("hop", hop);
			hopResult.put("documentId", currentDocId);
			hopResult.put("queryUsed", hopQuery);
			hopResult.put("snippets", retrieved.stream().map(Document::getText).toList());
			hopResult.put("nextReferences", nextRefs);

			hops.add(hopResult);  //contains HR, Finance, Tax

            // Move to next hop Next hop: pick the first reference (PDF_1 -> PDF_2 -> PDF_3)
			currentDocId = nextRefs.stream().findFirst().orElse(null);
		}

		return Map.of("query", query, "startDocumentId", startDocumentId, "tenantId", tenantId, "visited", visited,"hops", hops);
	}
}


