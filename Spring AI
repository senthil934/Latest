@Command
public class SpringAssistantCommand {

    //get azure ai model
    private final AzureOpenAiChatModel azureChatModel;

    //get access to vectorstore
    private final VectorStore vectorStore;

    //get access to the prompt
    @Value("classpath:/prompts/spring-boot-reference.st")
    private Resource sbPromptTemplate;

    //use constructor injection to inject the values
    public SpringAssistantCommand(AzureOpenAiChatModel azureChatModel, VectorStore vectorStore) {
        this.azureChatModel = azureChatModel;
        this.vectorStore = vectorStore;
    }

    @Command(command = "q")
    public String question(@Option(defaultValue = "What is Spring Boot") String message) {
        // Get similar documents from Vector Store
        List<String> similarDocs = findSimilarDocuments(message);
        String docsJoined = String.join("\n", similarDocs);

        // Create system and user messages
        SystemMessage system = new SystemMessage("You are a Spring Boot assistant. Use provided documents to answer.");
        UserMessage user = new UserMessage("Question: " + message + "\nRelevant Docs:\n" + docsJoined);

        // Create prompt
        Prompt prompt = new Prompt(List.of(system, user));

        // Call Azure OpenAI
        return azureChatModel.call(prompt).getResult().getOutput().getText();
    }

//we're doing a similarity search against our Vector stores, because we don't want to
send a thousand pages of PDF documents along with prompt to the LMS so we are getting just the relevant information to send 
    private List<String> findSimilarDocuments(String message) {
    	SearchRequest request = SearchRequest.builder().query(message).topK(3).build();
    	List<Document> similarDocuments = vectorStore.similaritySearch(request);

        return similarDocuments.stream()
                .map(Document::getText)
                .toList();
    }
}


@Component
@Command
public class SpringAssistantCommand {

    private final AzureOpenAiChatModel chatClient;
    private final VectorStore vectorStore;
    @Value("classpath:/prompts/spring-boot-reference.st")
    private Resource sbPromptTemplate;

    public SpringAssistantCommand(AzureOpenAiChatModel chatClient, VectorStore vectorStore) {
        this.chatClient = chatClient;
        this.vectorStore = vectorStore;
    }

    @Command(command = "q")
    public String question(@DefaultValue(value = "What is Spring Boot") String message) {
        PromptTemplate promptTemplate = new PromptTemplate(sbPromptTemplate);
        Map<String, Object> promptParameters = new HashMap<>();
        promptParameters.put("input", message);
        promptParameters.put("documents", String.join("\n", findSimilarDocuments(message)));

        return chatClient.call(promptTemplate.create(promptParameters))
                .getResult()
                .getOutput().getText();
                
    }

    private List<String> findSimilarDocuments(String message) {
       // List<Document> similarDocuments = vectorStore.similaritySearch(SearchRequest.query(message).withTopK(3));
    	List<Document> similarDocuments = vectorStore.similaritySearch(message);
        return similarDocuments.stream().map(Document::getFormattedContent).toList();
    }

}

