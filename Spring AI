4. Create producer to send feedback to kafka topic

@Component
public class FeedbackProducer {

	private final KafkaTemplate<String, String> template;

	@Value("${topics.input}")
	private String inputTopic;

	public FeedbackProducer(KafkaTemplate<String, String> template) {
		this.template = template;
	}

	public void send(FeedbackEvent event) {
		// serialize as JSON (for demo); prefer Avro/Schema Registry for prod

		String payloadTemplate = """
				{
				  "feedbackId": "%s",
				  "customerId": "%s",
				  "channel": "%s",
				  "text": "%s",
				  "ts": %d
				}
				""";

		String payload = payloadTemplate.formatted(event.feedbackId(), event.customerId(), event.channel(),
				event.text().replace("\"", "\\\""), event.ts());

		template.send(inputTopic, event.feedbackId(), payload);
	}
}


