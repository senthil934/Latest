@Component
public class ResourceWatcher {

    @Value("${resource.directory.path}")
    private String directoryPath;

    @Autowired
    private McpSyncServer mcpSyncServer;  //used to notify the client

    //set up a watcher 
    @PostConstruct
    public void start() throws Exception {

    	//to monitor the changes in this directory that we had specified in the application properties.
        FileAlterationObserver observer = new FileAlterationObserver(directoryPath);
        observer.addListener(new FileAlterationListenerAdaptor() {

            @Override
            public void onFileChange(final File file) {
                System.out.println("File created: " + file.getName());
                mcpSyncServer.notifyResourcesListChanged();  //once the file update, we will be notifying the MCP client that something has changed for this file
            }

        });
        
        //setting up this monitor so that it can run after every 2 seconds.
        new FileAlterationMonitor(2000, observer).start();
    }

}

This observer will keep on observing files after every 2 seconds. 

