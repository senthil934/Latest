@Service
public class AiService {

  // Spring will inject the provider-backed ChatModel bean (AzureOpenAiChatModel)
  private final ChatModel chatModel;

  private static final String SYSTEM_TEMPLATE = """
      You are an enterprise assistant. Answer concisely.
      If you are not confident, reply: "I don't know".
      Use only the information provided in the user's question and metadata when relevant.
      """;

  public AiService(ChatModel chatModel) {
    this.chatModel = chatModel;
  }

  public AnswerEvent generateAnswer(QuestionEvent q) {
    AnswerEvent answer = new AnswerEvent(q.getId(), null, List.of());
    answer.setStartedAt(Instant.now());


SystemPromptTemplate spt = new SystemPromptTemplate(SYSTEM_TEMPLATE);
    Prompt systemPrompt = spt.create(Map.of()); // <-- Prompt

    // Combine the system prompt messages with the user message into one Prompt
    Prompt fullPrompt = new Prompt(
        Stream.concat(
            systemPrompt.getInstructions().stream(),        // system messages (List<Message>)
            Stream.of(new UserMessage(q.getQuestion()))     // add user message
        ).toList()
    );

    ChatResponse resp = chatModel.call(fullPrompt);
    String content = resp.getResult().getOutput().getText().toString();
    
    answer.setAnswer(content);
    answer.setFinishedAt(Instant.now());
    return answer;

  }
}

