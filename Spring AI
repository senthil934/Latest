@Configuration
public class KafkaConfig {

	@Value("${app.inputtopic.name}")
	private String inputTopic;

	@Value("${app.outputtopic.name}")
	private String outputTopic;

	@Bean
	NewTopic incomingQuestions() {
		return TopicBuilder.name(inputTopic).partitions(3).replicas(1).build();
	}

	@Bean
	NewTopic aiResponses() {
		return TopicBuilder.name(outputTopic).partitions(3).replicas(1).build();
	}

// Convenience wrappers
	public static void sendQuestion(KafkaTemplate<String, QuestionEvent> template, QuestionEvent event, String topic) {
		template.send(topic, event.getId(), event);
	}

	public static void sendAnswer(KafkaTemplate<String, AnswerEvent> template, AnswerEvent event, String topic) {
		template.send(topic, event.getCorrelationId(), event);
	}
}

