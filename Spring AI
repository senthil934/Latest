@Slf4j
public class SimpleDateTimeTool {

	// information tool
	@Tool(description = "Get the current date and time in users zone.")
	public String getCurrentDateTime() {
		log.info("Tool calling");
		log.info("Get the current date and time in users zone.");
		return LocalDateTime.now().atZone(LocaleContextHolder.getTimeZone().toZoneId()).toString();
	}

	// action tool: that i can take action
	@Tool(description = "Set the alarm for given time.")
	void setAlarm(@ToolParam(description = "Time in ISO-8601 format") String time) {
		var dateTime = LocalDateTime.parse(time, DateTimeFormatter.ISO_DATE_TIME);
		log.info("Set the alarm for given time. {}", dateTime);
	}

	@Tool(name = "fx_rate", description = "Get current FX rate from base to quote (e.g., USD->INR).", returnDirect = true)
	public String getRate(@ToolParam(description = "Base currency code (e.g., 'USD')", required = true) String base,
			@ToolParam(description = "Quote currency code (e.g., 'INR')", required = true) String quote) {
		// TODO: Call your FX API and format the output
		return String.format("Rate %s/%s = %.4f", base, quote, 83.2105);
	}

}


returnDirect — Whether the tool’s result should be returned directly to the client instead of sending it back to the LLM to compose the final response.

Default is false (i.e., tool result goes back to the LLM first).
If you set it to true, the tool’s output is sent straight to the user.

