     var sysMsg = new SystemMessage(system);
     var userMsg = new UserMessage(user);

    Prompt p=new Prompt(List.of(sysMsg, userMsg));

    
    String response = chat.call(p).getResult().getOutput().getText().toString();

    try {
      JsonNode n = mapper.readTree(response);
      String sentiment = n.path("sentiment").asText("neutral");
      double confidence = n.path("confidence").asDouble(0.5);
      String summary = n.path("summary").asText("");
      return new FeedbackScore(feedbackId, sentiment, confidence, summary, Instant.now().toEpochMilli());
    } catch (Exception ex) {
      // fallback in case model returned non-JSON
      return new FeedbackScore(feedbackId, "neutral", 0.0, response, Instant.now().toEpochMilli());
    }
  }
