  public FeedbackAiService(ChatModel chatClient) {
    this.chat = chatClient;
  }

  public FeedbackScore score(String feedbackId, String text) {
    String system = """
      You are a precise sentiment analyst.
      Return a compact JSON with fields: sentiment(one of: positive, negative, neutral),
      confidence (0..1), summary (<=25 words).
      Do not include any extra commentary.
    """;

    String user = "Text: " + text;

    /*String response = chat.prompt()
        .system(system)
        .user(user)
        .call()
        .content();*/
    

     var sysMsg = new SystemMessage(system);
     var userMsg = new UserMessage(user);

    Prompt p=new Prompt(List.of(sysMsg, userMsg));

    
    String response = chat.call(p).getResult().getOutput().getText().toString();

    try {
      JsonNode n = mapper.readTree(response);
      String sentiment = n.path("sentiment").asText("neutral");
      double confidence = n.path("confidence").asDouble(0.5);
      String summary = n.path("summary").asText("");
      return new FeedbackScore(feedbackId, sentiment, confidence, summary, Instant.now().toEpochMilli());
    } catch (Exception ex) {
      // fallback in case model returned non-JSON
      return new FeedbackScore(feedbackId, "neutral", 0.0, response, Instant.now().toEpochMilli());
    }
  }
}

7. Create consumer and send score to another topic

@Component
public class FeedbackConsumer {

  private final FeedbackAiService ai;
  private final KafkaTemplate<String, String> template;
  private final ObjectMapper mapper = new ObjectMapper();

  @Value("${topics.output}")
  private String outputTopic;

  public FeedbackConsumer(FeedbackAiService ai, KafkaTemplate<String, String> template) {
    this.ai = ai; this.template = template;
  }

  @KafkaListener(topics = "${topics.input}", groupId = "genai-consumer", concurrency = "3")
  public void onMessage(ConsumerRecord<String, String> record, Acknowledgment ack) {
    try {
      JsonNode node = mapper.readTree(record.value());
      String feedbackId = node.path("feedbackId").asText();
      String text = node.path("text").asText();
      FeedbackScore scored = ai.score(feedbackId, text);
      String out = mapper.writeValueAsString(scored);
      template.send(outputTopic, feedbackId, out);
      ack.acknowledge(); // manual commit after successful processing
    } catch (Exception e) {
      // TODO: send to DLQ topic (events.raw.dlq) or retry with backoff
      ack.acknowledge();
    }
  }
}

