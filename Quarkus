@Path("/todos")
public class TodoResource {

	@RestClient
	TodoProxy proxy;

	@GET
	@Fallback(fallbackMethod = "getTodosByIdFallback")
	@Path("/{id}")
	public Response getTodosById(@PathParam("id") int id) {
		return Response.ok(proxy.getTodosById(id)).build();
	}

	public Response getTodosByIdFallback(int id){
        return Response.ok("Site is under maintenance").build();
    }
	
}

