@ApplicationScoped
public class BookService {

    private final BookRepository repo;

    public BookService(BookRepository repo) {
        this.repo = repo;
    }

    public List<Book> listAll() {
        return repo.listAll();
    }

    public Book get(long id) {
        return repo.findByIdOptional(id)
                .orElseThrow(() -> new NotFoundException("Book not found: " + id));
    }

    @Transactional
    public Book create(BookRequest req) {
        repo.findByIsbn(req.getIsbn()).ifPresent(b -> {
            throw new DuplicateResourceException("ISBN already exists: " + req.getIsbn());
        });

        Book b = new Book();
        b.title = req.getTitle();
        b.author = req.getAuthor();
        b.isbn = req.getIsbn();
        b.publishedOn = req.getPublishedOn();
        b.price = req.getPrice();

        repo.persist(b);
        return b;
    }

    @Transactional
    public Book update(long id, BookRequest req) {
        Book b = get(id);

        // If ISBN changes, ensure uniqueness
        if (req.getIsbn() != null && !req.getIsbn().equals(b.isbn)) {
            repo.findByIsbn(req.getIsbn()).ifPresent(existing -> {
                throw new DuplicateResourceException("ISBN already exists: " + req.getIsbn());
            });
        }

        b.title = req.getTitle();
        b.author = req.getAuthor();
        b.isbn = req.getIsbn();
        b.publishedOn = req.getPublishedOn();
        b.price = req.getPrice();

        return b;
    }

    @Transactional
    public void delete(long id) {
        Book b = get(id);
        repo.delete(b);
    }
}

