11. Building dynamic queries with optional parameters

public class MovieRepository {

  public static Uni<List<Movie>> search(
      MySQLPool client,
      Long id,                // optional (nullable)
      Integer age,            // optional (nullable)
      String titleContains,   // optional (nullable/blank)
      int limit,
      int offset
  ) {

    StringBuilder sql = new StringBuilder(
        "SELECT id, title FROM movies WHERE 1=1"
    );

    List<Object> params = new ArrayList<>();

    if (id != null) {
      sql.append(" AND id = ?");
      params.add(id);
    }

    if (age != null) {
      sql.append(" AND age = ?");
      params.add(age);
    }

    if (titleContains != null && !titleContains.isBlank()) {
      sql.append(" AND title LIKE ?");
      params.add("%" + titleContains + "%");
    }

    // Always apply deterministic order when paginating
    sql.append(" ORDER BY title DESC");

    // Pagination (MySQL supports LIMIT/OFFSET
    sql.append(" LIMIT ? OFFSET ?");
    params.add(limit);
    params.add(offset);

    Tuple tuple = Tuple.from(params); 

    return client
        .preparedQuery(sql.toString())
        .execute(tuple) // PreparedQuery.execute(Tuple) 
        .onItem()
        .transform(rows -> {
          List<Movie> list = new ArrayList<>();
          for (Row row : rows) {
            list.add(Movie.from(row)); 
          }
          return list;
        });
  }
}


