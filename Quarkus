    @NotBlank(message = "Name cannot be blank", groups = {BasicNameGroup.class, ExtendedNameGroup.class})
    @Length(min = 10, max = 50, message = "Name should be between 10 and 50 characters",
            groups = BasicNameGroup.class)
    @Length(min = 20, max = 100, message = "Name should be between 20 and 100 characters",
            groups = ExtendedNameGroup.class)
    String name;

    
    @Pattern(regexp = "[MF]",message = "Value can be either M or F")
    String gender;
    @Length(min = 12, max = 12, message = "Aadhar number must be 12 char")
    String aadharNo;
    @Min(value = 10,message = "Min age should be 10 yr")
    @Max(value = 24,message = "Max age should be 24 yr")
